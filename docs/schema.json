{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orthopredict.local/schema.json",
  "title": "OrthoPredict API Schema",
  "description": "Strict shared contract for the OrthoPredict v2 prediction request and response.",
  "type": "object",
  "additionalProperties": false,
  "required": ["age", "fracture_type", "bone_affected", "nutrition_score", "rehab_adherence", "bmi", "diabetes", "osteoporosis", "smoker"],
  "properties": {
    "age": {
      "type": "integer",
      "minimum": 1,
      "maximum": 110
    },
    "fracture_type": {
      "type": "string",
      "enum": ["hairline", "stress", "simple", "compound", "comminuted"]
    },
    "bone_affected": {
      "type": "string",
      "enum": ["femur", "tibia", "radius", "ulna", "humerus", "clavicle", "rib", "foot", "wrist", "other"]
    },
    "nutrition_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "rehab_adherence": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "bmi": {
      "type": "number",
      "minimum": 10.0,
      "maximum": 60.0
    },
    "diabetes": {
      "type": "boolean"
    },
    "osteoporosis": {
      "type": "boolean"
    },
    "smoker": {
      "type": "boolean"
    }
  },
  "$defs": {
    "prediction_response": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "predicted_weeks",
        "week_range_low",
        "week_range_high",
        "category",
        "week_range",
        "confidence",
        "uncertainty_weeks",
        "probabilities",
        "top_features",
        "driver_signals",
        "rehab_tips"
      ],
      "properties": {
        "predicted_weeks": {
          "type": "number",
          "exclusiveMinimum": 0.0
        },
        "week_range_low": {
          "type": "number",
          "minimum": 0.0
        },
        "week_range_high": {
          "type": "number",
          "minimum": 0.0
        },
        "category": {
          "type": "string",
          "enum": ["short", "medium", "long"]
        },
        "week_range": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "uncertainty_weeks": {
          "type": "number",
          "minimum": 0.0
        },
        "probabilities": {
          "type": "object",
          "required": ["short", "medium", "long"],
          "additionalProperties": false,
          "properties": {
            "short": { "type": "number" },
            "medium": { "type": "number" },
            "long": { "type": "number" }
          }
        },
        "top_features": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["feature", "importance"],
            "properties": {
              "feature": {
                "type": "string",
                "enum": ["age", "fracture_type", "bone_affected", "nutrition_score", "rehab_adherence", "bmi", "diabetes", "osteoporosis", "smoker"]
              },
              "importance": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              }
            }
          }
        },
        "driver_signals": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["feature", "effect_weeks", "direction"],
            "properties": {
              "feature": {
                "type": "string",
                "enum": ["age", "fracture_type", "bone_affected", "nutrition_score", "rehab_adherence", "bmi", "diabetes", "osteoporosis", "smoker"]
              },
              "effect_weeks": {
                "type": "number",
                "minimum": 0.0
              },
              "direction": {
                "type": "string",
                "enum": ["higher", "lower"]
              }
            }
          }
        },
        "rehab_tips": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "type": "string" }
        }
      }
    }
  }
}
